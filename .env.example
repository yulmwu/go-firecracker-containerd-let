# Runtime profile: runc | runsc(TODO) | kata(TODO) | firecracker(TODO)
SANDBOX_RUNTIME_PROFILE=runc

# containerd socket path
SANDBOX_CONTAINERD_ADDRESS=/run/containerd/containerd.sock

# Reconcile loop interval for daemon mode
# examples: 10s, 30s, 1m
SANDBOX_RECONCILE_INTERVAL=30s

# Chains to hook SANDBOX-FWD jump (comma-separated)
SANDBOX_FORWARD_HOOK_CHAINS=FORWARD,DOCKER-USER
